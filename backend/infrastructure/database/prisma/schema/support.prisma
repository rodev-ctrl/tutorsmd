model SupportChat {
  id        String   @id @default(uuid()) @db.Uuid
  userId    String   @unique @db.Uuid 
  createdAt DateTime @default(now()) @db.Timestamptz()

  user     User             @relation(fields: [userId], references: [id])
  messages SupportMessage[]

  @@map("support_chats")
}

model SupportMessage {
  id         String   @id @default(uuid()) @db.Uuid
  chatId     String   @db.Uuid
  senderId   String   @db.Uuid
  senderRole String   @db.VarChar(20) // "client" | "tutor" | "admin"
  text       String?  @db.Text
  createdAt  DateTime @default(now()) @db.Timestamptz()

  chat        SupportChat         @relation(fields: [chatId], references: [id])
  sender      User                @relation(fields: [senderId], references: [id])
  attachments SupportAttachment[]

  @@map("support_messages")
}

model SupportAttachment {
  id        String   @id @default(uuid()) @db.Uuid
  messageId String   @db.Uuid
  name      String   @db.VarChar(255)
  key       String   @db.Text
  mimeType  String   @db.VarChar(100)
  size      Int
  createdAt DateTime @default(now()) @db.Timestamptz()

  message SupportMessage @relation(fields: [messageId], references: [id], onDelete: Cascade)

  @@map("support_attachments")
}
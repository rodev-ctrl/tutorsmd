# в продакшене будем ходить по /api/ (Nginx проксирует /api → localhost:7898)
#REACT_APP_BACKEND_URL=/api/
REACT_APP_BACKEND_URL=http://localhost:7898/api/
REACT_APP_SOCKET_URL=http://localhost:7898

# базовый URL вашего сайта
#REACT_APP_CLIENT_URL=https://tutorsmd.net
REACT_APP_CLIENT_URL=http://localhost:3000

# остальные ваши REACT_APP_ переменные
REACT_APP_VIDEO_ID=2a113d017772431287eb280bd4b95b7d
#REACT_APP_STRIPE_PUBLIC_KEY=pk_test_client

# обязательно production, чтобы React собрался в режиме продакшена
NODE_ENV=production
